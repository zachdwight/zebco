# Healthcare ELT - Environment Configuration

# ============================================================================
# LLM API Keys
# ============================================================================

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-opus-4-6

# Google Gemini API
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-pro

# Local LLM (Ollama, Llama2, Mistral, etc.)
LOCAL_LLM_URL=http://localhost:11434
LOCAL_MODEL=mistral

# ============================================================================
# Default Settings
# ============================================================================

# Default LLM to use (claude, gemini, local)
DEFAULT_LLM=claude

# Maximum iterations for transformation attempts (1-10)
MAX_ITERATIONS=8

# Log verbosity (debug, info, warn, error)
LOG_LEVEL=info

# Enable debug mode
DEBUG=false

# ============================================================================
# File Paths
# ============================================================================

# Directory containing raw input files (bronze files)
BRONZE_DIR=./bronze

# Directory for transformed outputs
OUTPUT_DIR=./outputs

# Directory for logs
LOG_DIR=./transformations/logs

# ============================================================================
# Validation Settings
# ============================================================================

# Require 100% of required fields (1.0) or allow some missing (0.95)
REQUIRED_FIELD_THRESHOLD=1.0

# Percentage of records that must pass validation (0.995 = 99.5%)
VALIDATION_PASS_THRESHOLD=0.995

# ============================================================================
# Performance
# ============================================================================

# Timeout per API call (milliseconds)
API_TIMEOUT=300000

# Timeout per transformation iteration (milliseconds)
ITERATION_TIMEOUT=120000

# Batch size for processing records
BATCH_SIZE=100
